{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "allowSyntheticDefaultImports": true,
    "outDir": "./out/main"
  },
  "include": [
    "src/main/**/*.ts",
    "src/agents-private/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron-vite.config.ts"
  ]
}
