<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- V8 JIT compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Electron + native modules (better-sqlite3) require unsigned memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Loading native modules (.node files) not signed by the app's team.
         Required: better-sqlite3 and other npm native addons are compiled locally
         and cannot be signed with our team ID during npm install. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Gmail API, Claude API, electron-updater -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
